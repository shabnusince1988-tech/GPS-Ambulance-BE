{
  "openapi": "3.0.1",
  "info": {
    "title": "AmbulanceAPI",
    "version": "1.0"
  },
  "paths": {
    "/api/Mission/vitals": {
      "post": {
        "tags": [
          "Mission"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/VitalsUpdateDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/VitalsUpdateDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/VitalsUpdateDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "VitalsUpdateDto": {
        "type": "object",
        "properties": {
          "missionID": {
            "type": "integer",
            "format": "int32"
          },
          "heartRate": {
            "type": "integer",
            "format": "int32"
          },
          "spO2": {
            "type": "integer",
            "format": "int32"
          },
          "traumaLevel": {
            "type": "string",
            "nullable": true
          },
          "currentLat": {
            "type": "number",
            "format": "double"
          },
          "currentLng": {
            "type": "number",
            "format": "double"
          }
        },
        "additionalProperties": false
      }
    }
  }
}